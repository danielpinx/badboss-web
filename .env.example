# Redis 연결 URL (M-8: 인증 패스워드 포함)
# 로컬 개발: docker-compose up 후 REDIS_PASSWORD와 동일한 값 사용
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379

# Redis 인증 패스워드 (Docker Compose에서 사용)
# 반드시 강력한 비밀번호로 변경할 것 (32자 이상 권장)
REDIS_PASSWORD=

# CORS 허용 Origin (H-1: 프로덕션에서 반드시 특정 도메인으로 설정)
# 개발 환경: http://localhost:3000
# 프로덕션: https://your-domain.com
ALLOWED_ORIGIN=http://localhost:3000
